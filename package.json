{
  "name": "@cyanheads/arxiv-mcp-server",
  "version": "0.1.10",
  "description": "MCP server for arXiv academic paper search, metadata retrieval, and full-text reading.",
  "mcpName": "io.github.cyanheads/arxiv-mcp-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "arxiv-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "changelog:build": "bun scripts/build-changelog.ts",
    "changelog:check": "bun scripts/build-changelog.ts --check",
    "test": "vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "arxiv",
    "academic-papers",
    "research",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/arxiv-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/arxiv-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/arxiv-mcp-server/issues"
  },
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/arxiv-mcp-server#readme)",
  "license": "Apache-2.0",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.6.16",
    "fast-xml-parser": "^5.7.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^25.6.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
